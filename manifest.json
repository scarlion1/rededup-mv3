{
  "manifest_version": 3,
  "name": "Reddit Deduplicator",
  "version": "1.5",
  "author": "Nicholas Gaya",
  "description": "Hide duplicate posts on pre-redesign Reddit.",
  "homepage_url": "https://nickgaya.github.io/rededup/",

  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "*://*.reddit.com/*",
    "*://*.thumbs.redditmedia.com/*",
    "*://*.redd.it/*"
  ],

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": false
  },

  "background": {
  "service_worker": "background.js",
    "scripts": [
      "dct.js",
      "dwt.js",
      "phash.js",
      "background.js"
    ]
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://*.redd.it/*"
      ],
      "js": [
        "dct.js",
        "dwt.js",
        "phash.js",
        "settings.js",
        "rededup.js"
      ]
    }
  ],
  
  "action": {
    "default_title": "Reddit Deduplicator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "{68f0c654-5a3d-423b-b846-2b3ab68d05dd}"
    }
  }
}
