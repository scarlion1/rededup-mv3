{
  "manifest_version": 3,
  "name": "Reddit Deduplicator (MV3/2026 Firefox+redd.it Fix)",
  "version": "1.6",
  "author": "nickgaya, brsidell, scarlion1",
  "description": "Hide duplicate posts on pre-redesign Reddit, 2026 update supporting MV3, Firefox, and redd.it domain.",
  "homepage_url": "https://github.com/scarlion1/rededup-mv3/tree/fix/mv3-firefox-compatibility",

  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "*://*.reddit.com/*",
    "*://*.thumbs.redditmedia.com/*"
  ],

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": false
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*"
      ],
      "js": [
        "dct.js",
        "dwt.js",
        "phash.js",
        "settings.js",
        "rededup.js"
      ]
    }
  ],
  
  "action": {
    "default_title": "Reddit Deduplicator (MV3/2026 Firefox+redd.it Fix)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
